NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI APIs
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Stripe (opcional — configurar para suscripciones)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Internal API secret (auto-generated if not set)
# INTERNAL_API_SECRET=your_random_secret

# Slack (opcional — configurar para notificaciones)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_ALLOWED_CHANNELS=longevity-alerts,longevity-reports

# Ollama (local — alternativa a Anthropic)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2-vision
